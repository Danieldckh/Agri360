%% =========================================================
%% 1. PROPOSALS → BOOKING → ONBOARDING (Client Pipeline)
%% =========================================================

subgraph PROPOSALS["ADMIN — PROPOSALS"]
  direction TB
  A_outline["Proposal Outline"]
  A_ready["Proposal Ready"]
  A_sent["Proposal Sent"]
end

subgraph DESIGN_PROP["DESIGN — PROPOSALS"]
  direction TB
  DP_design["Design Proposal"]
  DP_review["Design Review"]
  DP_changes["Design Changes"]
end

subgraph BOOKING["ADMIN — BOOKING FORM"]
  direction TB
  B_accept["Proposal Accepted"]
  B_reviewed["Reviewed Booking Form"]
  B_sent["Booking Form Sent"]
end

subgraph ONBOARDING["ADMIN — ONBOARDING"]
  direction TB
  O_onboard["Onboarding"]
  O_create["Create Deliverables"]
  O_done["Onboarded"]
end

A_outline -->|Send to design| DP_design
DP_design --> DP_review
DP_review -->|Approved| A_ready
DP_review -->|Changes| DP_changes
DP_changes --> DP_review
A_ready -->|Send proposal| A_sent
A_sent -->|Client changes| DP_changes
A_sent -->|Client approves| B_accept
B_accept --> B_reviewed -->|Send form| B_sent

BF_decision{"Booking Form Response"}
BF_declined["Declined"]
B_sent --> BF_decision
BF_decision -->|Declined| BF_declined
BF_decision -->|Accepted| O_onboard
O_onboard --> O_create --> O_done

